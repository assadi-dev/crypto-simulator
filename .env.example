# ── Base de données (docker-compose : service postgres) ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crypto
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crypto

# ── Better Auth ──
# Générer un secret : openssl rand -base64 32
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000

# ── Supabase (accès client) ──
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54323
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── API /api/prices : rate limiting (optionnel) ──
# Nombre de requêtes autorisées par IP et durée de la fenêtre (en secondes).
# Valeurs par défaut si non défini : 30 requêtes / 60 s.
PRICES_RATE_LIMIT=30
PRICES_RATE_WINDOW=60

# ── MCP Context7 (outillage de dev, voir .mcp.json) ──
# Récupère/régénère ta clé sur https://context7.com
CONTEXT7_API_KEY=your-context7-api-key-here
